<?xml version="1.0"?>
<PropertyList>
 <generic>
  <input>
   <line_separator>newline</line_separator>
   <var_separator>comma</var_separator>
   
   <chunk>
    <name>latitude</name>
    <type>double</type>
    <format>%f</format>
    <node>/ai/models/multiplayer[0]/position/latitude-deg</node>
   </chunk>
   <chunk>
    <name>longitude</name>
    <type>double</type>
    <format>%f</format>
    <node>/ai/models/multiplayer[0]/position/longitude-deg</node>
   </chunk>
   <chunk>
    <name>altitude</name>
    <type>double</type>
    <format>%f</format>
    <node>/ai/models/multiplayer[0]/position/altitude-ft</node>
   </chunk>
   <chunk>
    <name>roll</name>
    <type>float</type>
    <format>%f</format>
    <node>/ai/models/multiplayer[0]/orientation/roll-deg</node>
   </chunk>
   <chunk>
    <name>pitch</name>
    <type>float</type>
    <format>%f</format>
    <node>/ai/models/multiplayer[0]/orientation/pitch-deg</node>
   </chunk>
   <chunk>
    <name>heading</name>
    <type>float</type>
    <format>%f</format>
    <node>/ai/models/multiplayer[0]/orientation/true-heading-deg</node>
   </chunk>
  </input>
 </generic>
</PropertyList>